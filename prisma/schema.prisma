

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

//プロフィールテーブル
model Profiles {
  id                    Int         @id @default(autoincrement())
  name                  String
  supabase_user_id      String      @unique
  height                Float
  target_weight         Float
  records               Records[]

  @@map("profiles")

}

//記録テーブル
model Records {
  id                    Int          @id @default(autoincrement())
  date                  DateTime     
  weight                Float
  steps                 Int
  memo                  String
  profileId             Int
  profile               Profiles     @relation(fields: [profileId], references: [id])

  @@unique([profileId, date])  // ← ユーザーごとに日付は一意
  @@map("records")
}

//faqテーブル
model Faq {
  id                    Int           @id @default(autoincrement())
  question              String
  answer                String

  @@("faq")
}

//お問い合わせテーブル
model Contact {
  id                    Int           @id @default(autoincrement())
  name                  String
  email                 String        @unique
  content               String
  createdAt             DateTime      @default(now())

  @@map("contact")
}